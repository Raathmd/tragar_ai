# Tragar Pastel SENDER — table map (config.toml).
#
# Target system: Sage 50c Pastel Partner v19.4.7  (Actian Zen / Pervasive PSQL).
# ODBC driver: "Pervasive ODBC Client Interface" (32-bit) — schema defined by the
# company dataset's DDFs (FILE.DDF / FIELD.DDF / INDEX.DDF).
#
# Secrets live in .env (see sender.env.example); this file holds the
# NON-secret table list, classes, watermark columns, and keys.
#
# Table NAMES below are the documented Pastel Partner ODBC names (verified against
# Sage KB) — treat as a strong model, but COLUMN names and especially the
# incremental WATERMARK column MUST still be confirmed against THIS install's
# live catalog (see docs/pastel-schema.md for the dump procedure). Anything marked
# TODO is unconfirmed.

[source]
name = "pastel"            # the <source> segment in batch_id ("<source>:<table>:<seq>")

[delivery]
batch_max_rows = 5000      # bounded read — Pervasive Workgroup connection ceiling; users are live
status_poll = true         # GET /ingest/status after a run to record processing outcomes

# Extraction strategy (DECIDED, confirmed against the dump):
#   transaction tables -> INCREMENTAL by watermark. Prefer a true monotonic
#     column IF the schema-dump reveals one (`watermark_cols = ["<that col>"]`);
#     otherwise fall back to the composite per-DocumentType watermark below
#     (track last DocumentNumber per DocumentType, pull WHERE > last).
#   master tables       -> snapshot + per-row hash (diff vs last loaded hash).
#   row-hash on history is the last-resort fallback if neither watermark holds.
# `class` drives RECEIVER upsert semantics; `keys` are the natural ON CONFLICT key.

# ── transaction streams (append-mostly posted documents) ────────────────────
[[table]]
name           = "HistoryHeader"               # logical stream -> <table> in batch_id
class          = "transaction"
odbc_table     = "HistoryHeader"               # acchisth.dat (confirmed name)
keys           = ["DocumentType", "DocumentNumber"]   # composite document key
watermark_cols = ["DocumentType", "DocumentNumber"]   # per-type fallback; replace with monotonic col if dump shows one
trim_keys      = ["CustomerCode"]              # space-padded; TRIM before batching

[[table]]
name           = "HistoryLines"                # acchistl.dat (confirmed name)
class          = "transaction"
odbc_table     = "HistoryLines"
keys           = ["DocumentType", "DocumentNumber", "LineNumber"]  # TODO confirm line key col
watermark_cols = ["DocumentType", "DocumentNumber"]                # per-type fallback; see above
trim_keys      = []

# OpenItem holds receipts / payments / allocations that HistoryHeader excludes.
# Include only if the read model needs them — keys TBD from the live catalog.
# [[table]]
# name           = "OpenItem"
# class          = "transaction"
# odbc_table     = "OpenItem"
# keys           = []                           # TODO
# watermark_cols = []                           # TODO
# trim_keys      = ["CustomerCode"]

# ── master streams ──────────────────────────────────────────────────────────
# Full snapshot + per-row hash; diff vs last loaded hash so unchanged rows no-op.

[[table]]
name          = "CustomerMaster"               # confirmed name; key CustomerCode (space-padded)
class         = "master"
odbc_table    = "CustomerMaster"
keys          = ["CustomerCode"]
trim_keys     = ["CustomerCode"]
row_hash_cols = []                              # [] = hash all selected columns

[[table]]
name          = "SupplierMaster"
class         = "master"
odbc_table    = "SupplierMaster"
keys          = ["SupplierCode"]               # TODO confirm exact column name
trim_keys     = ["SupplierCode"]
row_hash_cols = []

[[table]]
name          = "InventoryMaster"
class         = "master"
odbc_table    = "InventoryMaster"
keys          = ["ItemCode"]                    # TODO confirm exact column name
trim_keys     = ["ItemCode"]
row_hash_cols = []
