# Tragar Pastel SENDER — table map (config.toml).
#
# Secrets live in .env (see sender.env.example); this file holds the
# NON-secret table list, classes, watermark columns, and keys.
#
# ⚠️ UNCONFIRMED: every table / column name below is a MODEL of the Pastel
# schema, NOT verified against the live install. Before full build-out we must
# inspect the real Pastel DB via the ODBC catalog (SQLTables / SQLColumns) to
# get true table names, the monotonic record-number column per transaction
# table, and the key columns. Do not trust these defaults.

[source]
name = "pastel"            # the <source> segment in batch_id ("<source>:<table>:<seq>")

[delivery]
batch_max_rows = 5000      # bounded read — Pervasive Workgroup connection ceiling; users are live
status_poll = true         # GET /ingest/status after a run to record processing outcomes

# ── transaction streams ─────────────────────────────────────────────────────
# Append-only Pastel history/journal tables. Incremental pull WHERE
# record_number_col > watermark. Watermark is the MONOTONIC RECORD NUMBER, never
# the transaction date (backdated postings still get a higher record number).

[[table]]
name              = "HistoryHeader"     # logical stream -> <table> in batch_id
class             = "transaction"
odbc_table        = "HistoryHeader"     # TODO: real Pervasive table name
record_number_col = "RecordNumber"      # TODO: monotonic watermark column
keys              = ["RecordNumber"]    # natural key for ON CONFLICT upsert
trim_keys         = ["AccountID"]       # space-padded keys to TRIM before batching

[[table]]
name              = "HistoryLines"
class             = "transaction"
odbc_table        = "HistoryLines"
record_number_col = "RecordNumber"
keys              = ["RecordNumber"]
trim_keys         = ["AccountID"]

# ── master streams ──────────────────────────────────────────────────────────
# Customer / Supplier / LedgerMaster / Inventory etc. Full snapshot + per-row
# hash; diff vs last loaded hash so unchanged rows no-op. Mutate in place.

[[table]]
name          = "Customer"
class         = "master"
odbc_table    = "CustomerMaster"        # TODO: real name
keys          = ["CustomerCode"]
trim_keys     = ["CustomerCode"]
row_hash_cols = []                       # [] = hash all selected columns

[[table]]
name          = "Supplier"
class         = "master"
odbc_table    = "SupplierMaster"
keys          = ["SupplierCode"]
trim_keys     = ["SupplierCode"]
row_hash_cols = []

[[table]]
name          = "Inventory"
class         = "master"
odbc_table    = "InventoryMaster"
keys          = ["ItemCode"]
trim_keys     = ["ItemCode"]
row_hash_cols = []
