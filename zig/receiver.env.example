# Tragar Pastel RECEIVER (.env) — the mini. SECRETS ONLY. Never commit.

# ── HTTPS listener ────────────────────────────────────────────────────────────
LISTEN_ADDR=0.0.0.0:8443
TLS_CERT_PATH=/etc/tragar/ingest/cert.pem
TLS_KEY_PATH=/etc/tragar/ingest/key.pem
BATCH_TOKEN=                      # shared bearer secret; must match the sender
BATCH_ENCRYPTION_KEY=             # base64 of 32 random bytes; MUST match the sender

# ── Local Postgres on the mini (loopback -> sslmode=disable is fine) ─────────
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=tragar_ai_prod
PG_USER=postgres
PG_PASSWORD=
PG_SSLMODE=disable
# Schema names: where staging, the read model, and the ingestion ledger live.
PG_SCHEMA_STAGING=pastel_staging
PG_SCHEMA_READMODEL=pastel
PG_SCHEMA_LEDGER=pastel_ingest
