# Tragar Pastel SENDER (.env) — Windows box. SECRETS ONLY (table map is in config.toml).
# Copy to .env next to the sender binary. Restrictive ACL; never commit.

# ── Pervasive / Actian Zen side (read Pastel via 32-bit Windows ODBC) ────────
PASTEL_ODBC_DRIVER=Pervasive ODBC Unicode Interface
PASTEL_DB_SERVER=localhost
PASTEL_NAMED_DB=
PASTEL_DATA_PATH=
# Optional: use a pre-configured 32-bit DSN instead of a DSN-less connect string.
PASTEL_ODBC_DSN=
# Pastel engine user/pass — usually blank on Workgroup installs.
PASTEL_DB_USER=
PASTEL_DB_PASSWORD=

# ── Delivery side (outbound HTTPS to the mini) ───────────────────────────────
MINI_BASE_URL=https://tragar.local
BATCH_TOKEN=                      # shared bearer secret; must match the receiver
BATCH_ENCRYPTION_KEY=             # base64 of 32 random bytes; MUST match the receiver
#   generate: openssl rand -base64 32

# ── Local state / files ──────────────────────────────────────────────────────
OUTBOX_DIR=C:\Tragar\outbox
STATE_PATH=C:\Tragar\state\sender_state.db
LOG_FILE=C:\Tragar\logs\sender.log
