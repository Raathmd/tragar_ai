# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where 3rd-party dependencies like ExDoc output generated docs.
/doc/

# Ignore .fetch files in case you like to edit your project deps locally.
/.fetch

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Temporary files, for example, from tests.
/tmp/

# Ignore package tarball (built via "mix hex.build").
tragar_ai-*.tar

# Ignore assets that are produced by build tools.
/priv/static/assets/

# Ignore digested assets cache.
/priv/static/cache_manifest.json

# In case you use Node.js/npm, you want to ignore these.
npm-debug.log
/assets/node_modules/


# Swift sidecar build artifacts
/sidecar/.build/

# Local secrets (loaded by config/runtime.exs in dev)
.env
# Prod/other env files hold live secrets — never commit them.
.env.*

# Local operational helper (prompts for prod credentials; not for the repo)
/switch-freightware-prod.sh
/switch-freightware-prod.sh.sha256

# Zig build artifacts (zig/ Pastel ingestion programs)
/zig/**/.zig-cache/
/zig/**/zig-out/

# macOS
.DS_Store
/set-claude-api-key.sh
/set-claude-api-key.sh.sha256
/discover-vantage.sh
/discover-vantage.sh.sha256
/vantage-sample.json
/set-vantage-creds.sh
/set-vantage-creds.sh.sha256

# FDK (Freshdesk app) runtime artifacts when run from repo root
/.fdk/
/log/

# FreightWare DB schema dump (generated by freightware-db-explore.sh)
freightware-schema.txt
