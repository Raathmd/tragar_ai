# Copy to .env and fill in. Read at runtime in config/runtime.exs.

# ── Core AI (the local model) ───────────────────────────────────────────────
# ollama = talk directly to Ollama/qwen3:30b at CORE_AI_URL (/api/chat); if qwen
#          is down it falls back to the in-process stub automatically. (mini)
# http   = POST to the optional coreai sidecar (/interpret, /phrase).
# stub   = deterministic in-process interpreter/phraser (no model needed).
CORE_AI_MODE=stub
CORE_AI_URL=http://127.0.0.1:11434
# qwen3 is a hybrid reasoning model: the app sends /no_think for fast interpret +
# grounded answers, and lets it think only when "reason freely" is toggled on.
# One model serves both. qwen3:14b (balanced) or qwen3:8b (faster).
CORE_AI_MODEL=qwen3:14b
# Optional: a SEPARATE deeper model for "reason freely" (e.g. qwen3:30b-a3b).
# Unset = use CORE_AI_MODEL (with thinking) for reasoning too.
# CORE_AI_REASON_MODEL=qwen3:30b-a3b
# CORE_AI_TIMEOUT_MS=180000

# ── FreightWare (Dovetail) — source: load status, ETA, waybill, POD ─────────
# DOVETAIL_ENV (uat|prod) selects the credential set below. Per-env vars win,
# then the generic DOVETAIL_* fallback. base_url default by env if unset:
#   uat  -> http://tragar-db.dovetail.co.za:5001/WebServices/web
#   prod -> http://tragar-db.dovetail.co.za:4001/WebServices/web
DOVETAIL_ENV=uat

# UAT set
DOVETAIL_UAT_BASE_URL=
DOVETAIL_UAT_USERNAME=
DOVETAIL_UAT_PASSWORD=
DOVETAIL_UAT_STATION=

# PROD (live) set
DOVETAIL_PROD_BASE_URL=http://tragar-db.dovetail.co.za:4001/WebServices/web
DOVETAIL_PROD_USERNAME=
DOVETAIL_PROD_PASSWORD=
DOVETAIL_PROD_STATION=

# Optional generic fallback (used if the per-env var above is unset):
# DOVETAIL_BASE_URL=  DOVETAIL_USERNAME=  DOVETAIL_PASSWORD=  DOVETAIL_STATION=
DOVETAIL_POD_IMAGE_BASE=https://tragar-db.dovetail.co.za/FWO_UAT/views/viewImage.html

# ── Freshdesk — source: ticket context + customer ───────────────────────────
# Account domain only (e.g. "tragar" for https://tragar.freshdesk.com).
FRESHDESK_DOMAIN=
FRESHDESK_API_KEY=
# Company custom-field key holding the FreightWare account code(s). Default cf_account.
FRESHDESK_ACCOUNT_FIELD=cf_account

# ── Vantage — source: telematics / trip data (multi.vantage.run) ─────────────
VANTAGE_BASE_URL=https://multi.vantage.run
VANTAGE_EMAIL=
VANTAGE_PASSWORD=

# ── Inbound API auth (Freddy/Freshdesk → /api, /mcp) ─────────────────────────
# Bearer token callers must send. Mint with: openssl rand -hex 32
TRAGAR_API_KEY=
# IP allowlist (CSV of CIDRs) — restrict to Freshworks egress. Empty = allow all (dev).
TRAGAR_API_ALLOWED_IPS=
# Behind a tunnel/proxy, name the header carrying the real client IP (e.g. cf-connecting-ip).
TRAGAR_API_CLIENT_IP_HEADER=
TRAGAR_API_TRUST_XFF=

# ── Database (prod releases) ────────────────────────────────────────────────
# DATABASE_URL=ecto://USER:PASS@HOST/tragar_ai
# SECRET_KEY_BASE=

# Sources pending read-only access: Granite, Pastel, FleetIT.
