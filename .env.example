# Copy to .env and fill in. These are read in config/runtime.exs.

# ── Dovetail (FreightWare) ──────────────────────────────────────────────────
# "uat" or "prod" — selects the default base URL below if DOVETAIL_BASE_URL unset.
DOVETAIL_ENV=uat
# Override the base URL if needed (defaults derived from DOVETAIL_ENV):
#   uat  -> https://tragar-db.dovetail.co.za/WebServicesUAT/web
#   prod -> https://tragar-db.dovetail.co.za/WebServices/web
DOVETAIL_BASE_URL=
DOVETAIL_USERNAME=
DOVETAIL_PASSWORD=
DOVETAIL_STATION=
DOVETAIL_POD_IMAGE_BASE=https://tragar-db.dovetail.co.za/FWO_UAT/views/viewImage.html

# ── Freshdesk ───────────────────────────────────────────────────────────────
# Account domain only (e.g. "tragar" for https://tragar.freshdesk.com),
# or a full host / URL.
FRESHDESK_DOMAIN=
FRESHDESK_API_KEY=
# Shared secret to authenticate inbound Freshdesk webhooks.
FRESHDESK_WEBHOOK_SECRET=

# ── Database (prod releases) ────────────────────────────────────────────────
# DATABASE_URL=ecto://USER:PASS@HOST/tragar_ai
# SECRET_KEY_BASE=
