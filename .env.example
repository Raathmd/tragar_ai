# Copy to .env and fill in. Read at runtime in config/runtime.exs.

# ── Core AI (the local model sidecar) ───────────────────────────────────────
# stub = deterministic in-process interpreter/phraser (no model needed).
# http = POST to a local model at CORE_AI_URL (/interpret, /phrase).
CORE_AI_MODE=stub
CORE_AI_URL=http://127.0.0.1:11434

# ── FreightWare (Dovetail) — source: load status, ETA, waybill, POD ─────────
DOVETAIL_ENV=uat
# Defaults derived from DOVETAIL_ENV if unset:
#   uat  -> https://tragar-db.dovetail.co.za/WebServicesUAT/web
#   prod -> https://tragar-db.dovetail.co.za/WebServices/web
DOVETAIL_BASE_URL=
DOVETAIL_USERNAME=
DOVETAIL_PASSWORD=
DOVETAIL_STATION=
DOVETAIL_POD_IMAGE_BASE=https://tragar-db.dovetail.co.za/FWO_UAT/views/viewImage.html

# ── Freshdesk — source: ticket context + customer ───────────────────────────
# Account domain only (e.g. "tragar" for https://tragar.freshdesk.com).
FRESHDESK_DOMAIN=
FRESHDESK_API_KEY=
# Company custom-field key holding the FreightWare account code(s). Default cf_account.
FRESHDESK_ACCOUNT_FIELD=cf_account

# ── Vantage — source: telematics / trip data (multi.vantage.run) ─────────────
VANTAGE_BASE_URL=https://multi.vantage.run
VANTAGE_EMAIL=
VANTAGE_PASSWORD=

# ── Inbound API auth (Freddy/Freshdesk → /api, /mcp) ─────────────────────────
# Bearer token callers must send. Mint with: openssl rand -hex 32
TRAGAR_API_KEY=
# IP allowlist (CSV of CIDRs) — restrict to Freshworks egress. Empty = allow all (dev).
TRAGAR_API_ALLOWED_IPS=
# Behind a tunnel/proxy, name the header carrying the real client IP (e.g. cf-connecting-ip).
TRAGAR_API_CLIENT_IP_HEADER=
TRAGAR_API_TRUST_XFF=

# ── Database (prod releases) ────────────────────────────────────────────────
# DATABASE_URL=ecto://USER:PASS@HOST/tragar_ai
# SECRET_KEY_BASE=

# Sources pending read-only access: Granite, Pastel, FleetIT.
